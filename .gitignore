# ============================================================
# OS / Editor
# ============================================================
.DS_Store
**/.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# ============================================================
# Secrets & local config — NEVER commit
# ============================================================
.env
.env.*
.mcp.json
*.pem
*.key
*secret*
*credentials*

# ============================================================
# Claude Code — local-only state
# ============================================================
.claude/audit.log
.claude/settings.local.json
# /orchestrate umbrella mode creates per-step worktrees (full repo checkouts) here
.claude/worktrees/
# Local read-usage telemetry written by track-memory-read.sh (per-clone, not shared)
.claude/memory-usage.json
# Atomic-write temp from the same hook (jq > $DB.tmp && mv) — a crash can leave it behind
.claude/*.tmp
# Guard against accidental copy of ~/.claude/projects/ (transcripts + auto-memory) into repo
**/.claude/projects/

# ============================================================
# Python
# ============================================================
.venv/
**/.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

