{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "${CLAUDE_PROJECT_ROOT}/plugins/git-conventions/hooks/validate-branch-name.md",
            "if": "Bash(git checkout -b *)"
          },
          {
            "type": "prompt",
            "prompt": "${CLAUDE_PROJECT_ROOT}/plugins/git-conventions/hooks/validate-branch-name.md",
            "if": "Bash(git branch *)"
          },
          {
            "type": "prompt",
            "prompt": "${CLAUDE_PROJECT_ROOT}/plugins/git-conventions/hooks/validate-branch-name.md",
            "if": "Bash(git switch -c *)"
          },
          {
            "type": "prompt",
            "prompt": "${CLAUDE_PROJECT_ROOT}/plugins/git-conventions/hooks/validate-commit-message.md",
            "if": "Bash(git commit *)"
          }
        ]
      }
    ]
  }
}
